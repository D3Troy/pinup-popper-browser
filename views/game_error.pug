extends layout

block content
  nav.navbar.fixed-top.px-3.bg-body-tertiary(data-bs-theme="dark")
    div#navbarRight.d-flex.align-items-center.ms-auto.gap-2
      a(href='/', title="Home")
        i.bi.bi-house-fill.fs-4
  #game.container-fluid
    div.row
      div.col-sm-5.col-md-4.col-xl-3.mb-3
        img.wheel(src='/images/unavailable.png', alt='Unavailable')
      div.col
        div.alert.alert-danger(role='alert') #{message}
        div.row
          div.col
            button#btnBack.btn.btn-secondary(type='button') Go Back
