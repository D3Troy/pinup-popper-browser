extends layout

block content
  nav.navbar.navbar-expand-lg.fixed-top.px-3.bg-body-tertiary(data-bs-theme="dark")
    button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarNav', aria-controls='navbarNav', aria-expanded='false', aria-label='Toggle navigation')
      span.navbar-toggler-icon
    if showHome
      div#navbarRight.d-flex.align-items-center.ms-auto.order-md-last.gap-2
        a(href=homeUrl, title="Home")
          i.bi.bi-house-fill.fs-4
    div.collapse.navbar-collapse(id='navbarNav')
      ul.navbar-nav.nav.me-auto
        li.nav-item
          a.nav-link(href='/home') Home
        li.nav-item
          a.nav-link.active(href='/playlists') Playlists

  div.container-fluid

    if error
      div.alert.alert-danger(role='alert') #{error}

    if !items.length && !error
      div.alert.alert-info(role='alert') No items found.

    div#playlistsRow.row.g-0
      each item in items
        div.col-6.col-md-4.col-lg-3.col-xl-2.my-auto.game
          div.wheel-wrap
            a(href=item.link, title=item.display, data-bs-toggle='tooltip', data-go-back=item.goBack ? 'true' : null)
              img.wheel.img-fluid.lazyload(
                class=item.cssClass,
                src=item.placeholder,
                data-src=item.src,
                alt=item.display
              )
            if item.gameId
              i.bi.favorite(class=item.favorite ? 'bi-star-fill' : 'bi-star', data-gameid=item.gameId, data-fav=item.favorite)
