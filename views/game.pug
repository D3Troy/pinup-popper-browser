extends layout

block content
  nav.navbar.navbar-expand-md.fixed-top.px-3.bg-body-tertiary(data-bs-theme="dark")
    button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarNav', aria-controls='navbarNav', aria-expanded='false', aria-label='Toggle navigation')
      span.navbar-toggler-icon
    div#navbarRight.d-flex.align-items-center.ms-auto.order-md-last.gap-2
      a(href=homeUrl, title="Home")
        i.bi.bi-house-fill.fs-4
      a(href='/settings', title="Settings")
        i.bi.bi-gear-fill.fs-5
    #navbarNav.collapse.navbar-collapse
      ul#tabs.navbar-nav.nav
        li.nav-item
          a.nav-link.navbar-brand(href='#home', data-bs-toggle='tab') #{game.display}
        if (info)
          li.nav-item
            a.nav-link(href='#info', data-bs-toggle='tab', data-gameid=game.id) Info
        if (help)
          li.nav-item
            a.nav-link(href='#help', data-bs-toggle='tab', data-gameid=game.id) Help
        if (playfield)
          li.nav-item
            a.nav-link(href='#playfield', data-bs-toggle='tab', data-gameid=game.id) Playfield
        if (media)
          li.nav-item
            a.nav-link(href='#media', data-bs-toggle='tab') Media
        if (highscore)
          li.nav-item
            a.nav-link(href='#highscore', data-bs-toggle='tab', data-gameid=game.id) Highscore

  #game.container-fluid(data-gameid=game.id, data-refresh=refreshInterval)
    div.tab-content
      #home.tab-pane.fade
        div.game-home-layout
          div.game-wheel-col
            div.wheel-wrap
              img.wheel.lazyload(class='rotate'+wheelRotation, src='/images/wheel_loading_'+wheelRotation+'.gif', data-src=getWheelSrc(game))
              i.bi.favorite(class=game.favorite ? 'bi-star-fill' : 'bi-star', data-gameid=game.id, data-fav=game.favorite, title="Favorite")
          div.game-right-col
            div.game-info-card
              div.game-stats
                -
                  const fieldMeta = {
                    year:            { icon: 'calendar3',          label: 'Year' },
                    type:            { icon: 'controller',          label: 'Type' },
                    manufacturer:    { icon: 'building',            label: 'Manufacturer' },
                    numPlayers:      { icon: 'people',              label: 'Players' },
                    emulator:        { icon: 'cpu',                 label: 'Emulator' },
                    category:        { icon: 'tag',                 label: 'Category' },
                    theme:           { icon: 'palette',             label: 'Theme' },
                    lastPlayed:      { icon: 'clock-history',       label: 'Last Played' },
                    numPlays:        { icon: 'play-circle',         label: 'Times Played' },
                    timePlayed:      { icon: 'hourglass-split',     label: 'Time Played' },
                    designedBy:      { icon: 'person-badge',        label: 'Designed By' },
                    webLinkUrl:      { icon: 'link-45deg',          label: 'Web Link' },
                    gameVersion:     { icon: 'hash',                label: 'Version' },
                    gameDescription: { icon: 'info-circle',         label: 'Description' },
                    romName:         { icon: 'file-earmark-binary', label: 'ROM' },
                    tableType:       { icon: 'table',               label: 'Table Type' },
                  }
                each field in gameFields
                  - const meta = fieldMeta[field]
                  if field === 'rating'
                    div.game-stat
                      i.bi.bi-star-half.game-stat-icon
                      span.game-stat-label Rating
                      span.game-stat-value
                        span.rating-wrap(data-gameid=game.id, data-rating=game.rating)
                          each n in [1,2,3,4,5]
                            i.bi.rating-star(class=(game.rating >= n ? 'bi-star-fill' : 'bi-star'), data-value=n)
                  else if meta
                    div.game-stat
                      i(class=`bi bi-${meta.icon} game-stat-icon`)
                      span.game-stat-label #{meta.label}
                      if field === 'lastPlayed'
                        if game.lastPlayed
                          span.game-stat-value(data-lastplayed=game.lastPlayed data-dateformat=dateFormat data-locale=locale) Loading…
                        else
                          span.game-stat-value Never
                      else if field === 'timePlayed'
                        - var t = game.timePlayed || 0; var h = Math.floor(t/3600), m = Math.floor((t%3600)/60), s = t%60
                        span.game-stat-value #{t ? (h ? h+'h ' : '') + (m ? m+'m ' : (h ? '0m ' : '')) + s+'s' : '—'}
                      else if field === 'webLinkUrl'
                        if game.webLinkUrl
                          span.game-stat-value
                            a.btn.btn-sm.btn-outline-secondary.py-0(href=game.webLinkUrl, target='_blank', rel='noopener')
                              i.bi.bi-box-arrow-up-right.me-1
                              | Visit
                        else
                          span.game-stat-value —
                      else if field === 'emulator'
                        span.game-stat-value #{game.emulator && game.emulator.name || '—'}
                      else
                        - const val = game[field]
                        span.game-stat-value #{(val !== undefined && val !== null && val !== '') ? val : '—'}
            div.game-actions
              #response.mb-2
              div.d-flex.align-items-center.gap-2
                button#btnBack.btn.btn-secondary(type='button', data-back-url=playlistId ? '/playlists/' + playlistId : null)
                  i.bi.bi-arrow-left-circle
                  span.btn-label-back.ms-1 Go Back
                div.ms-auto.d-flex.align-items-center.gap-2
                  button#btnExit.btn.btn-warning(type='button', data-id=game.id) Exit Current Game
                  button#btnLaunch.btn.btn-primary.px-4(type='button', data-id=game.id) Launch Game

      if media
        - const hasLeftMedia = !!(media.topper || media.backglass || media.dmd || media.info || media.help)
        #media.tab-pane.fade
          .media-two-col
            if hasLeftMedia
              .media-left-col
                #mediaStack
                  if (media && media.topper)
                    .media-ov-block.media-ov-block--topper
                      .media-ov-slot-wrap
                        #mediaTopper.media-ov-slot
                  if (media && media.backglass)
                    .media-ov-block
                      .media-ov-slot-wrap
                        #mediaBackglass.media-ov-slot
                  if (media && media.dmd)
                    .media-ov-block
                      .media-ov-slot-wrap
                        #mediaDMD.media-ov-slot
                  if (media && (media.info || media.help))
                    .media-ov-block.media-ov-block--half.media-ov-row
                      if (media && media.info)
                        .media-ov-slot-wrap
                          #mediaInfo.media-ov-slot
                      if (media && media.help)
                        .media-ov-slot-wrap
                          #mediaHelp.media-ov-slot
            if (media && media.playfield)
              .media-right-col
                .media-ov-slot-wrap
                  #mediaPlayfield.media-ov-slot

      #info.tab-pane.fade
        #carouselInfo.carousel.slide(data-bs-ride='carousel')
          div.carousel-inner
          button.carousel-control-prev(type='button', data-bs-target='#carouselInfo', data-bs-slide='prev')
            span.carousel-control-prev-icon(aria-hidden='true')
            span.visually-hidden Previous
          button.carousel-control-next(type='button', data-bs-target='#carouselInfo', data-bs-slide='next')
            span.carousel-control-next-icon(aria-hidden='true')
            span.visually-hidden Next
      #help.tab-pane.fade
        #carouselHelp.carousel.slide(data-bs-ride='carousel')
          div.carousel-inner
          button.carousel-control-prev(type='button', data-bs-target='#carouselHelp', data-bs-slide='prev')
            span.carousel-control-prev-icon(aria-hidden='true')
            span.visually-hidden Previous
          button.carousel-control-next(type='button', data-bs-target='#carouselHelp', data-bs-slide='next')
            span.carousel-control-next-icon(aria-hidden='true')
            span.visually-hidden Next
      #playfield.tab-pane.fade(data-rotate=playfieldRotation)

      if highscore
        #highscore.tab-pane.fade
          #carouselHighscore.carousel.slide(data-bs-ride='carousel')
            div.carousel-inner
            button.carousel-control-prev(type='button', data-bs-target='#carouselHighscore', data-bs-slide='prev')
              span.carousel-control-prev-icon(aria-hidden='true')
              span.visually-hidden Previous
            button.carousel-control-next(type='button', data-bs-target='#carouselHighscore', data-bs-slide='next')
              span.carousel-control-next-icon(aria-hidden='true')
              span.visually-hidden Next
