extends layout

block content
  nav.navbar.navbar-expand-md.fixed-top.px-3.bg-body-tertiary(data-bs-theme="dark")
    button.navbar-toggler(type='button', data-bs-toggle='collapse', data-bs-target='#navbarNav', aria-controls='navbarNav', aria-expanded='false', aria-label='Toggle navigation')
      span.navbar-toggler-icon
    div#navbarRight.d-flex.align-items-center.ms-auto.order-md-last.gap-2
      a(href="/home", title="Home")
        i.bi.bi-house-fill.fs-4
    #navbarNav.collapse.navbar-collapse
      ul#tabs.navbar-nav.nav
        li.nav-item
          a.nav-link.navbar-brand(href='#home', data-bs-toggle='tab') #{game.display}
        if (info)
          li.nav-item
            a.nav-link(href='#info', data-bs-toggle='tab', data-gameid=game.id) Info
        if (help)
          li.nav-item
            a.nav-link(href='#help', data-bs-toggle='tab', data-gameid=game.id) Help
        if (playfield)
          li.nav-item
            a.nav-link(href='#playfield', data-bs-toggle='tab', data-gameid=game.id) Playfield

  #game.container-fluid(data-gameid=game.id, data-refresh=refreshInterval)
    div.tab-content
      #home.tab-pane.fade
        div.row
          div.col-sm-5.col-md-4.col-xl-3.mb-3
            img.wheel.lazyload(class='rotate'+wheelRotation, src='/images/wheel_loading_'+wheelRotation+'.gif', data-src=getWheelSrc(game))
            if game.favorite
              i.bi.bi-star-fill.favorite(title="Favorite")
          div.col
            h4.text-nowrap
              span.badge.bg-primary Year 
                span.badge.bg-light.text-dark #{game.year}
              span.badge.bg-dark.ms-2 Type 
                span.badge.bg-light.text-dark #{game.type}
            h4
              span.badge.bg-secondary Manufacturer 
                span.badge.bg-light.text-dark #{game.manufacturer}
            h4
              span.badge.bg-success Number of Players 
                span.badge.bg-light.text-dark #{game.numPlayers}
            h4
              span.badge.bg-danger Emulator 
                span.badge.bg-light.text-dark #{game.emulator.name}                
            h4
              span.badge.bg-warning.text-dark Times Played 
                span.badge.bg-light.text-dark #{game.numPlays || 0}    
            h4
              span.badge.bg-info.text-dark Last Played 
                span.badge.bg-light.text-dark #{game.lastPlayed ? game.lastPlayed.toLocaleString() : 'Never'}                        
            hr
            div.row
              div.col
                button#btnLaunch.btn.btn-primary(type='button', data-id=game.id) Launch Game
                button#btnBack.btn.btn-secondary.ms-2(type='button', data-back-url=playlistId ? '/playlists/' + playlistId : null) Go Back
            div.row.mt-2
              #response.col
            div.row.mt-2
              div.col
                button#btnExit.btn.btn-primary(type='button', data-id=game.id) Exit Current Game

      #info.tab-pane.fade
        #carouselInfo.carousel.slide(data-bs-ride='carousel')
          div.carousel-inner
          button.carousel-control-prev(type='button', data-bs-target='#carouselInfo', data-bs-slide='prev')
            span.carousel-control-prev-icon(aria-hidden='true')
            span.visually-hidden Previous
          button.carousel-control-next(type='button', data-bs-target='#carouselInfo', data-bs-slide='next')
            span.carousel-control-next-icon(aria-hidden='true')
            span.visually-hidden Next
      #help.tab-pane.fade
        #carouselHelp.carousel.slide(data-bs-ride='carousel')
          div.carousel-inner
          button.carousel-control-prev(type='button', data-bs-target='#carouselHelp', data-bs-slide='prev')
            span.carousel-control-prev-icon(aria-hidden='true')
            span.visually-hidden Previous
          button.carousel-control-next(type='button', data-bs-target='#carouselHelp', data-bs-slide='next')
            span.carousel-control-next-icon(aria-hidden='true')
            span.visually-hidden Next
      #playfield.tab-pane.fade(data-rotate=playfieldRotation)


